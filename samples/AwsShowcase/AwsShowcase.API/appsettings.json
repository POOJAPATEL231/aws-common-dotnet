{
  "Urls": "http://localhost:8080",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AwsShowcase": "Debug"
    }
  },
  "AllowedHosts": "*",
  "AWS": {
    "Region": "us-east-1"
  },
  "LocalStack": {
    "UseLocalStack": true,
    "Session": {
      "AwsAccessKeyId": "test",
      "AwsAccessKey": "test",
      "AwsSessionToken": "test",
      "RegionName": "us-east-1"
    },
    "Config": {
      "LocalStackHost": "localhost",
      "EdgePort": 4566
    }
  },
  "Showcase": {
    "SelfBaseUrl": "http://localhost:8080",
    "CacheProvider": "Memory",
    "FeatureProvider": "Ssm",
    "UseHttpUser": false,
    "EnableXRay": false
  },
  "EventBridge": {
    "EventBusName": "default",
    "Source": "com.showcase.orders"
  },
  "Cognito": {
    "UserPoolId": "us-east-1_example"
  },
  "CognitoAuth": {
    "BaseUrl": "",
    "ClientId": "",
    "ClientSecret": "",
    "Scope": ""
  },
  "AppSettings": {
    "AuthSettings": {
      "Type": 0
    }
  },
  "AwsInfraSettings": {
    "EventDispatcherFunctionName": "",
    "DefaultVisibilityTimeoutInSeconds": 30,
    "Queues": {
      "ordercreated_Queue.fifo": {
        "QueueName": "ordercreated_Queue.fifo",
        "MaxConcurrentCalls": 5,
        "MaxRetryCount": 3,
        "MessageRetentionPeriodInSeconds": 1209600,
        "VisibilityTimeoutInSeconds": 30,
        "RetryDelaysSeconds": [ 30, 60, 120 ]
      }
    }
  },
  "AppConfig": {
    "ApplicationIdentifier": "aws-showcase",
    "EnvironmentIdentifier": "dev",
    "ConfigurationProfileIdentifier": "feature-flags",
    "PollIntervalSeconds": 60
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "SqsConsumer": {
    "Enabled": true,
    "EventNames": [ "OrderCreatedIntegrationEvent" ],
    "WaitTimeSeconds": 10,
    "MaxMessagesPerPoll": 10,
    "ErrorBackoffSeconds": 30
  },
  "Features": {
    "new-checkout": true
  },
  "AwsTags": {
    "DefaultTags": [
      { "Key": "app", "Value": "aws-showcase" }
    ]
  }
}
