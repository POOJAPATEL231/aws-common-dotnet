{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AwsShowcase": "Debug"
    }
  },
  "AllowedHosts": "*",
  "AWS": {
    "Region": "us-east-1"
  },
  "LocalStack": {
    "UseLocalStack": true,
    "Session": {
      "AwsAccessKeyId": "test",
      "AwsAccessKey": "test",
      "AwsSessionToken": "test",
      "RegionName": "us-east-1"
    },
    "Config": {
      "LocalStackHost": "localhost",
      "EdgePort": 4566
    }
  },
  "EventBridge": {
    "EventBusName": "default",
    "Source": "com.showcase.orders"
  },
  "Cognito": {
    "UserPoolId": "us-east-1_example"
  },
  "AwsTags": {
    "DefaultTags": [
      { "Key": "app", "Value": "aws-showcase" }
    ]
  }
}
